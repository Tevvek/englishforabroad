{
    "$schema": "https://openapi.vercel.sh/microfrontends.json",
    "applications": {
        "english-for-abroad": {
            "development": {
                "fallback": "www.englishforabroad.com"
            }
        },
        "english-for-abroad-dashboard": {
            "routing": [
                {
                    "paths": [
                        "/auth/sign-in",
                        "/dashboard/:path*",
                        "/api/auth/:path*"
                    ]
                }
            ]
        }
    }
}