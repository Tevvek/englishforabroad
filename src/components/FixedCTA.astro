---
import BookDiscoveryCall from "@/components/BookDiscoveryCall.astro";
import cn from "@/utils/cn";

const { class: className } = Astro.props;
---

<BookDiscoveryCall
  id="calendly-cta"
  style="z-index: var(--z-index-cta);"
  class={cn(
    "fixed right-0 top-1/5 z-cta origin-bottom-right rotate-[270deg] rounded-b-none px-8 pointer-events-auto isolate",
    className
  )}
/>
