---
import Logo from "@/components/Logo.astro";
import MobileNavbar from "@/components/MobileNavbar.svelte";
import { NAV } from "@/utils/constants";

const firstHalf = NAV.slice(0, Math.ceil(NAV.length / 2));
const secondHalf = NAV.slice(Math.ceil(NAV.length / 2));
---

<header class="sticky top-0 hidden bg-background px-4 py-4 lg:block relative isolate z-navbar" style="z-index: var(--z-index-navbar);">
  <div class="pointer-events-none absolute inset-x-0 top-full h-14 bg-gradient-to-b from-background via-background/85 to-transparent"></div>
  <div class="mx-auto grid max-w-6xl grid-cols-[1fr_max-content_1fr] items-center gap-x-8 text-foreground">
    <!-- first half -->
    <nav class="flex justify-end items-center gap-x-4">
      {
        firstHalf.map((item) => (
          <a
            class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground transition hover:text-primary focus:text-primary"
            href={item.href}
          >
            {item.text}
          </a>
        ))
      }
    </nav>

    <!-- logo -->
    <div class="size-[88px] rounded-full border bg-card p-2 shadow-xs">
      <a href="/#">
        <Logo />
      </a>
    </div>

    <!-- second half -->
    <nav class="flex items-center gap-x-4">
      {
        secondHalf.map((item) => (
          <a
            class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground transition hover:text-primary focus:text-primary"
            href={item.href}
          >
            {item.text}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<MobileNavbar client:load>
  <Logo />
</MobileNavbar>
