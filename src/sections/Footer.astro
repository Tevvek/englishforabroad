---
import TikTok from "@/icons/tiktok.svg";
import Instagram from "@/icons/instagram.svg";
import Facebook from "@/icons/facebook.svg";
import KakaoTalk from "@/icons/kakaotalk.svg";
import YouTube from "@/icons/youtube.svg";
import Container from "@/components/Container.astro";

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="border-t bg-card text-card-foreground">
  <Container tag="div" class="py-8 md:py-12">
    <div class="space-y-4">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Contact</p>
      <h2 class="text-3xl">Let's keep in touch</h2>
      <div class="flex gap-x-4 text-muted-foreground [&_svg]:size-5">
        <a
          href="https://www.instagram.com/englishforabroad/"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-primary focus:text-primary"
        >
          <Instagram />
        </a>
        <a
          href="https://www.tiktok.com/@englishforabroad_"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-primary focus:text-primary"
        >
          <TikTok />
        </a>
        <a
          href="https://www.facebook.com/englishforabroad"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-primary focus:text-primary"
        >
          <Facebook />
        </a>
        <a
          href="https://open.kakao.com/o/englishforabroad"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-primary focus:text-primary"
        >
          <KakaoTalk />
        </a>
        <a
          href="https://www.youtube.com/@englishforabroad"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-primary focus:text-primary"
        >
          <YouTube />
        </a>
      </div>
      <div class="pb-4">
        <a
          class="font-semibold text-primary underline decoration-primary/40 underline-offset-4 transition hover:text-foreground focus:text-foreground"
          href="mailto:ali@englishforabroad.com"
        >
          ali@englishforabroad.com
        </a>
      </div>

      <div class="grid grid-cols-2 grid-rows-[auto_auto] gap-x-4 gap-y-2 border-t pt-4 md:grid-cols-1">
        <a
          class="justify-self-end text-right text-sm text-muted-foreground underline underline-offset-4 transition hover:text-primary focus:text-primary md:justify-self-start md:text-start"
          href="/legal-notice"
        >
          Legal notice
        </a>
        <a
          class="justify-self-start text-sm text-muted-foreground underline underline-offset-4 transition hover:text-primary focus:text-primary"
          href="/privacy-policy"
        >
          Privacy policy
        </a>
        <p class="col-span-2 text-sm text-muted-foreground md:col-span-1 md:text-start">
          &copy; English for Abroad. All Rights Reserved {currentYear}
        </p>
      </div>
    </div>
  </Container>
</footer>
