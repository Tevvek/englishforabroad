---
import { Image } from "astro:assets";
import { Button } from "@/components/ui/button";
import { Card as UiCard, CardContent } from "@/components/ui/card";
// import BottomLeftBlob from "@/components/blobs/BottomLeftBlob.astro";
// import BottomRightBlob from "@/components/blobs/BottomRightBlob.astro";
import aliImage from "@/images/ali.webp";
import BigArrowRight from "@/icons/BigArrowRight.astro";
---

<section class="relative overflow-x-hidden" id="hero">
  <!-- Hero blobs -->
  <!-- <div class="absolute bottom-0 right-0 -z-10 hidden sm:block">
    <BottomRightBlob />
  </div>

  <div class="absolute bottom-0 left-0 -z-10">
    <BottomLeftBlob />
  </div> -->

  <div
    class="mx-auto grid max-w-6xl grid-cols-[minmax(250px,550px)] place-items-center place-content-center gap-y-10 px-4 pt-12 md:px-8 md:pt-24 lg:grid-cols-[minmax(250px,560px)_max-content] lg:grid-rows-5 lg:gap-x-20 lg:pr-0"
  >
    <!-- Title & Description -->
    <div
      class="space-y-5 text-center lg:row-span-4 lg:row-start-1 lg:text-start"
    >
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Private English coaching that feels personal</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl">Launch your English journey with confident, natural speaking.</h1>
      <p class="max-w-2xl text-base text-muted-foreground md:text-lg lg:max-w-xl">
        Hi! I'm Ali, an American English teacher offering personalized ESL
        classes. With an educational foundation from Georgetown University and
        two master's degrees, I specialize in one-on-one classes tailored to fit
        the goals and learning styles of students at all levels. Let's work
        together to build your confidence and skills in English!
      </p>

      <!-- CTA -->
      <Button
        href=""
        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/englishforabroad/trial-esl-class'});return false;"
        class="h-10 w-full gap-x-2 uppercase tracking-[0.18em] md:mx-auto md:w-fit lg:mx-0"
      >Book Discovery Call<BigArrowRight />
      </Button>

      <UiCard class="mx-auto max-w-xl bg-card/95 lg:mx-0">
        <CardContent class="grid gap-3 pt-6 text-left sm:grid-cols-3">
          <div>
            <p class="text-2xl font-semibold text-primary">1:1</p>
            <p class="text-sm text-muted-foreground">Tailored sessions around your goals</p>
          </div>
          <div>
            <p class="text-2xl font-semibold text-primary">1000+</p>
            <p class="text-sm text-muted-foreground">Learners supported with real speaking practice</p>
          </div>
          <div>
            <p class="text-2xl font-semibold text-primary">Global</p>
            <p class="text-sm text-muted-foreground">Lessons built for life abroad and everyday confidence</p>
          </div>
        </CardContent>
      </UiCard>
    </div>

    <!-- Hero image -->
    <Image
      src={aliImage}
      alt="Ali"
      width="500"
      height="500"
      class="lg:row-span-5 lg:row-start-1 rounded-[2rem] border bg-card p-2 shadow-lg"
      loading="eager"
    />
  </div>
</section>
