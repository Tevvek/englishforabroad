---
import { Button } from "@/components/ui/button";
import { Card as UiCard, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import BigArrowRight from "@/icons/BigArrowRight.astro";
import WaitlistForm from "../components/forms/WaitlistForm.svelte";
---

<section id="services">
  <div
    class="mx-auto max-w-6xl space-y-6 overflow-x-hidden px-4 py-12 md:px-8 md:py-16"
  >
    <p class="text-center text-xs font-semibold uppercase tracking-[0.22em] text-primary">Offerings</p>
    <h2 class="text-center text-5xl">Services</h2>
    <h3 class="text-center text-2xl text-muted-foreground md:text-3xl">
      Custom English Coaching
    </h3>

    <div class="grid gap-6 md:grid-cols-2">
      <UiCard>
        <CardHeader>
          <CardTitle class="text-center text-xl tracking-wide">1:1 ENGLISH COACHING</CardTitle>
          <CardDescription class="text-center text-base">
          Personalized support to help you speak English naturally and
          confidently
          </CardDescription>
        </CardHeader>
        <CardContent class="space-y-5">
        <ul class="list-disc space-y-2 pl-5 text-sm text-muted-foreground marker:text-primary">
          <li>
            Lessons fully customized to your goals, profession, interests, and
            communication style
          </li>
          <li>
            Weekly live sessions focused on fluency, tone, expression, and
            practical communication
          </li>
          <li>
            Ongoing access to a shared Google Doc with notes, assignments,
            vocabulary, and feedback
          </li>
          <li>
            Personalized materials and class replays available to help you
            review and stay on track
          </li>
          <li>Individual support between sessions via KakaoTalk or WhatsApp</li>
          <li>
            Includes 12 private sessions (50 minutes each) to use over 15 weeks
            — $600 total or 3 payments of $200
          </li>
        </ul>
        <p class="text-sm text-muted-foreground">Book a free discovery call to get started.</p>

        <div class="flex justify-center">
          <Button
            href=""
            onclick="Calendly.initPopupWidget({url: 'https://calendly.com/englishforabroad/trial-esl-class'});return false;"
            class="h-10 w-full gap-x-2 uppercase tracking-[0.18em] md:w-fit"
          >Book Discovery Call<BigArrowRight />
          </Button>
        </div>
        </CardContent>
      </UiCard>

      <UiCard class="relative">
        <CardHeader>
          <CardTitle class="text-center text-xl tracking-wide">
          BLOSSOM 🌸
          </CardTitle>
          <CardDescription class="text-center text-base">
          Build speaking confidence abroad with a community of women
          </CardDescription>
        </CardHeader>
        <CardContent class="space-y-5">
        <ul class="list-disc space-y-2 pl-5 text-sm text-muted-foreground marker:text-primary">
          <li>
            You feel stuck when speaking and worry that you come across as awkward or overly formal
          </li>
          <li>
            You struggle to express your opinions, likes, and dislikes in a natural way
          </li>
          <li>
            You already have a solid foundation in basic English grammar and vocabulary, but you struggle to actually use it in real life conversations
          </li>
          <li>
            You rely on filler words like “ums” and “uhs” when you don’t know what to say
          </li>
        </ul>
        <p class="text-sm text-muted-foreground">
          Enter your email to join the waitlist and get updates on class dates,
          tips, and early access to offers.
        </p>
        <WaitlistForm client:load />
        </CardContent>
      </UiCard>
    </div>
  </div>
</section>
