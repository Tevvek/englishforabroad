---
import FreebieLayout from "@/layouts/FreebieLayout.astro";
import FreebieForm from "../../components/forms/FreebieForm.svelte";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import resolveFreebieImage from "@/utils/resolveFreebieImage";

export async function getStaticPaths() {
  const freebies = await getCollection("freebies");
  return freebies.map((freebie) => ({
    params: { slug: freebie.data.slug },
    props: { freebie },
  }));
}

const { freebie } = Astro.props;
const {
  title,
  subtitle,
  description,
  slug,
  buttonText,
  metaTitle,
  metaDescription,
  image,
} = freebie.data;

const resolvedImage = resolveFreebieImage(image);
---

<FreebieLayout title={metaTitle || title} description={metaDescription || description}>
  <main class="min-h-screen flex items-center justify-center py-16 md:py-24 px-4 md:px-8 lg:px-12 xl:px-16">
    <div class="text-balance text-center max-w-3xl w-full">
      {subtitle && (
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.22em] text-primary">
          {subtitle}
        </p>
      )}
      <h1 class="mb-6 text-4xl md:text-6xl leading-tight">
        {title}
      </h1>
      <p class="mb-8 text-lg leading-relaxed text-muted-foreground">
        {description}
      </p>
      <FreebieForm client:load freebieSlug={slug} buttonText={buttonText} />
      {resolvedImage && (
        <div class="mt-10 md:mt-12">
          <Image
            src={resolvedImage}
            alt={title}
            class="mx-auto w-full max-w-xl rounded-[2rem] border bg-card p-2 shadow-lg"
          />
        </div>
      )}
    </div>
  </main>
</FreebieLayout>
