---
import FreebieLayout from "@/layouts/FreebieLayout.astro";
import WatchAndLearnForm from "../components/forms/WatchAndLearnForm.svelte";
import { CircleCheck } from "lucide-svelte";
import { Image } from "astro:assets";

import resourcesImage from "@/assets/freebie/01-resources.webp";
import watchAndLearnImage from "@/assets/freebie/02-watch-and-learn.webp";
import stepsImage from "@/assets/freebie/03-steps.webp";

import aliImage from "@/images/ali.webp";
import Section from "@/components/Section.astro";
import { cn } from "@/lib/utils";
---

<FreebieLayout>
  <main class="overflow-x-hidden">
    <!-- Hero section -->
    <Section id="hero" class="text-balance text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.22em] text-primary">
        Stuck in that "I understand, but I can't speak" feeling?
      </p>
      <h1 class="mb-6 text-4xl leading-tight md:text-6xl">
        Learn to speak English Confidently using TV SHOWS!
      </h1>
      <p class="mb-8 text-lg text-muted-foreground leading-relaxed">
        Subscribe to get your free guide, plus language tips and early access to
        new offers and resources to help you speak English with confidence.
      </p>
      <WatchAndLearnForm client:load />
    </Section>

    <Section
      class="bg-gradient-to-b from-background from-50% to-50% to-card pt-0 md:pt-0"
    >
      <div
        class="flex relative aspect-[210/297] w-[clamp(12rem,_50vw,_28rem)] mx-auto"
      >
        <div
          class={cn(
            // width
            "aspect-[210/297] w-[clamp(12rem,_50vw,_28rem)]",

            // transformations
            "absolute inset-0 -translate-x-[clamp(3rem,_10vw,_20rem)] translate-y-16 -rotate-6"
          )}
        >
          <Image
            src={resourcesImage}
            alt="Resources"
            class="size-full rounded-2xl border object-cover object-top-left shadow-lg"
          />
        </div>
        <div
          class={cn(
            // width
            "aspect-[210/297] w-[clamp(12rem,_50vw,_28rem)]",

            // transformations
            "absolute inset-0 z-10"
          )}
        >
          <Image
            src={watchAndLearnImage}
            alt="Watch and Learn"
            class="size-full rounded-2xl border object-cover object-top-left shadow-lg"
          />
        </div>
        <div
          class={cn(
            // width
            "aspect-[210/297] w-[clamp(12rem,_50vw,_28rem)]",

            // transformations
            "absolute inset-0 translate-x-[clamp(3rem,_10vw,_20rem)] translate-y-8 rotate-6"
          )}
        >
          <Image
            src={stepsImage}
            alt="Steps"
            class="size-full rounded-2xl border object-cover object-top-left shadow-lg"
          />
        </div>
      </div>
    </Section>

    <!-- What'll you get section -->
    <Section id="what-you-get" class="rounded-[2rem] border bg-card text-center shadow-sm">
      <h2
        class="mb-6 text-3xl font-bold leading-tight uppercase md:text-4xl"
      >
        What's included?
      </h2>

      <div class="text-left grid md:grid-cols-2 gap-4 md:gap-8 mb-12">
        <div class="flex items-start space-x-3">
          <CircleCheck className="mt-1 h-5 w-5 flex-shrink-0 text-primary" />
          <span class="text-muted-foreground">
            Easy, low-pressure ways to turn your TV time into real speaking
            practice
          </span>
        </div>
        <div class="flex items-start space-x-3">
          <CircleCheck className="mt-1 h-5 w-5 flex-shrink-0 text-primary" />
          <span class="text-muted-foreground">
            Tricks to build English into your routine in a way that feels fun &
            flexible
          </span>
        </div>
        <div class="flex items-start space-x-3">
          <CircleCheck className="mt-1 h-5 w-5 flex-shrink-0 text-primary" />
          <span class="text-muted-foreground">
            Tools to gain the confidence to talk about shows in English
          </span>
        </div>
        <div class="flex items-start space-x-3">
          <CircleCheck className="mt-1 h-5 w-5 flex-shrink-0 text-primary" />
          <span class="text-muted-foreground">
            Access to dozens of show recommendations for practicing English
          </span>
        </div>
      </div>
    </Section>

    <!-- About me section -->
    <Section id="about-me" class="text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.22em] text-primary">
        Behind the guide
      </p>
      <h2
        class="mb-6 text-3xl font-bold leading-tight uppercase md:text-4xl"
      >
        Hi! I'm Ali
      </h2>

      <div class="grid md:grid-cols-2 place-items-center gap-8">
        <Image
          src={aliImage}
          alt="Hi! I'm Ali! Your english teacher"
          class="w-full max-w-sm rounded-[2rem] border bg-card p-2 shadow-lg md:col-start-2 place-self-center"
        />

        <div class="space-y-4 text-left md:col-start-1 md:row-start-1">
          <p class="text-lg text-muted-foreground leading-relaxed">
            I help English learners who understand a lot but still feel stuck
            when it's time to speak. If you're tired of studying lots and still
            not feeling confident in real conversations, you're not alone!
          </p>
          <p class="text-lg text-muted-foreground leading-relaxed">
            With two Master's degrees and over 1,000 students taught, I focus on
            helping you sound natural, speak with confidence, and enjoy
            expressing yourself in English, especially when you're abroad and
            want to connect with others in real life.
          </p>
        </div>
      </div>
    </Section>

    <!-- Footer -->
    <Section id="footer" class="rounded-[2rem] border bg-primary text-center text-balance text-primary-foreground shadow-lg" tag="footer">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.22em] text-primary-foreground/80">
        Stuck in that "I understand, but I can't speak" feeling?
      </p>
      <h2 class="mb-6 text-3xl leading-tight md:text-4xl">
        Learn to speak English Confidently using TV SHOWS!
      </h2>
      <p class="mb-8 text-lg leading-relaxed text-primary-foreground/80">
        Subscribe to get your free guide, plus language tips and early access to
        new offers and resources to help you speak English with confidence.
      </p>

      <WatchAndLearnForm client:load />
    </Section>
  </main>
</FreebieLayout>
