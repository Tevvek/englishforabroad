---
import FreebieLayout from "@/layouts/FreebieLayout.astro";
import WaitlistForm from "./_waitlist-form";
import { CheckCircle } from "lucide-react";
import { Image } from "astro:assets";

import aliImage from "@/images/ali.webp";
import Section from "@/components/Section.astro";

const layout = {
  title:
    "Online Group English Course for Korean Women | 한국 여성을 위한 온라인 영어 그룹 수업",
  description:
    "Join the waitlist for an online English course designed for Korean women preparing for life abroad. 자연스럽고 자신 있게 영어로 말하세요. 해외 생활을 준비하는 한국 여성을 위한 안전하고 따뜻한 영어 연습 공간입니다.",
};
---

<FreebieLayout {...layout}>
  <main class="bg-surface overflow-x-hidden">
    <!-- Hero section -->
    <Section id="hero" class="text-balance text-center">
      <p class="text-sm font-medium text-gray-600 mb-4 tracking-wide uppercase">
        Ready to stop overthinking your English and start feeling confident abroad?
      </p>
      <h1 class="text-4xl md:text-6xl text-gray-900 mb-6 leading-tight">
        Join the Waitlist for Blossom 🌸
      </h1>
      <p class="text-lg text-gray-700 mb-4 leading-relaxed">
        Blossom is a friendly, speaking-focused group course for Korean women in their 20s and 30s living abroad (or preparing to move soon). If you understand most English but freeze in small talk, feel awkward sounding “too formal,” or struggle to speak up in everyday situations, you’re in the right place!
      </p>
      <p class="text-lg text-gray-700 mb-4 leading-relaxed">
        The first course will run for about 6 weeks, starting mid–late April. Full schedule and curriculum details are coming soon.
      </p>
      <p class="text-lg text-gray-700 mb-8 leading-relaxed">
        Spots will be limited! To make sure everyone feels comfortable, I’ll place members into groups by speaking level (so you’re with people in a similar range). When enrollment opens, I’ll email waitlist members first with the details and the quick level check!
      </p>
      <WaitlistForm client:visible />
    </Section>

    <!-- What'll you get section -->
    <Section id="what-you-get" class="bg-white text-center">
      <h2
        class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-tight uppercase"
      >
        This class is for you if...
      </h2>

      <div class="text-left grid md:grid-cols-2 gap-4 md:gap-8 mb-12">
        <div class="flex items-start space-x-3">
          <CheckCircle className="h-5 w-5 text-orange-500 mt-1 flex-shrink-0" />
          <span class="text-gray-700">
            You feel stuck when speaking and worry that you come across as awkward or overly formal
          </span>
        </div>
        <div class="flex items-start space-x-3">
          <CheckCircle className="h-5 w-5 text-orange-500 mt-1 flex-shrink-0" />
          <span class="text-gray-700">
            You struggle to express your opinions, likes, and dislikes in a natural way
          </span>
        </div>
        <div class="flex items-start space-x-3">
          <CheckCircle className="h-5 w-5 text-orange-500 mt-1 flex-shrink-0" />
          <span class="text-gray-700">
            You already have a solid foundation in basic English grammar and vocabulary, but you struggle to actually use it in real life conversations
          </span>
        </div>
        <div class="flex items-start space-x-3">
          <CheckCircle className="h-5 w-5 text-orange-500 mt-1 flex-shrink-0" />
          <span class="text-gray-700">
            You rely on filler words like “ums” and “uhs” when you don’t know what to say
          </span>
        </div>
      </div>
    </Section>

    <!-- About me section -->
    <Section id="about-me" class="bg-surface text-center">
      <p class="text-sm font-medium text-gray-600 mb-4 tracking-wide uppercase">
        Who's your teacher?
      </p>
      <h2
        class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-tight uppercase"
      >
        Hi, I am Ali 🩷
      </h2>

      <div class="grid md:grid-cols-2 place-items-center gap-8">
        <Image
          src={aliImage}
          alt="Hi, I am Ali 🩷"
          class="md:col-start-2 place-self-center max-w-sm w-full"
        />

        <div class="space-y-4 text-left md:col-start-1 md:row-start-1">
          <p class="text-lg text-gray-700 leading-relaxed">
            I have taught over 1,000 Korean English learners and specialize in conversation skills for intermediate and advanced speakers. I have an academic background from Georgetown and two Master degrees, but I know firsthand that all the textbook studying in the world does not prepare you for the reality of making friends in a second language!
          </p>
          <p class="text-lg text-gray-700 leading-relaxed">
            As an immigrant living far away from my home country, I know exactly how frustrating it is to feel like the vocabulary is stuck in your brain but never comes out when you actually need it. Blossom is the exact community I wish I had when I first moved abroad!
          </p>
        </div>
      </div>
    </Section>

    <!-- Footer -->
    <Section id="footer" class="bg-black text-center text-balance" tag="footer">
      <p class="text-sm font-medium mb-4 tracking-wide uppercase text-white">
        Ready to stop overthinking your English and start feeling confident abroad?
      </p>
      <h2 class="text-3xl md:text-4xl mb-6 leading-tight text-white">
        Join the Waitlist for Blossom 🌸
      </h2>
      <p class="text-lg mb-8 leading-relaxed text-white">
        Sign up to receive your exclusive level match invite when doors open!
      </p>

      <WaitlistForm client:visible />
    </Section>
  </main>
</FreebieLayout>
